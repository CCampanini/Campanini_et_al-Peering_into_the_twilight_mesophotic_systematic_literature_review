View(new_spec)
table(polar$meso_protection)
polar$visuallySurveyedSurface <- as.factor(polar$visuallySurveyedSurface)
summary(subset(polar, is.na(polar$taxonomic_publication))$visuallySurveyedSurface)
print(paste("Number of manipulative experimental studies:",nrow(subset(polar, grepl("exp", polar$observationalORexperimental)))))
print(paste("Number of manipulative experimental studies in the field of restoration:", nrow(subset(polar, grepl("exp", polar$observationalORexperimental) & polar$field_rest != 0)
)
)
)
print(paste("# Publications that included temporal replicates:", nrow(subset(polar, grepl("yes", temporalReplicates)))))
print(paste("# Publications that included temporal replicates:", nrow(subset(polar, (grepl("exp", polar$observationalORexperimental) & grepl("yes", temporalReplicates))))))
print(paste("# Publications relying on a manipulative experiment that included temporal replicates:", nrow(subset(polar, (grepl("exp", polar$observationalORexperimental) & grepl("yes", temporalReplicates))))))
health <- subset(polar, grepl("Health", indicators) | grepl("Disease", indicators))
unique(health$targetTaxa)
rov <- subset(polar, grepl("rov", meso_samplingPlatform) )
rov_specimen <- subset(rov,  grepl("specimen", collectedDataType) )
print(paste("Percentage of publications relying solely on ROV where specimens were collected:", round(nrow(rov_specimen)/nrow(rov)*100,1),"%"))
rm(rov, rov_specimen)
polar$taxonomic_publication <- as.factor(polar$taxonomic_publication )
molecular <- polar %>%
filter(molecularAnalyses != "no" &
molecularAnalyses != "notapp" &
molecularAnalyses != "nd")
print(paste("# Publications that adopted molecular techniques: ",nrow(molecular)))
molecular_notaxa <- molecular %>%
filter(is.na(taxonomic_publication))
print(paste("# Publications that adopted molecular techniques not for taxonomy: ",nrow(molecular_notaxa)))
rm(molecular, molecular_notaxa)
